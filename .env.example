NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
APIFY_TOKEN=your-apify-token
# Optional: Apify token can also be saved in Supabase via Settings page (takes priority over env)
# APIFY_TOKEN=your-apify-token

# Required for AI Insights (server-side only, never commit real keys)
# Can also be saved in Supabase via Settings page (takes priority over env)
GEMINI_API_KEY=your-gemini-api-key
# Default: gemini-2.0-flash
# GEMINI_MODEL=gemini-2.0-flash
# Skip Apify if account synced within this many minutes (default 360 = 6h). Sync Now uses force=true.
APIFY_SYNC_CACHE_MINUTES=360
TRACKER_PASSWORD=zhaoeven
TRACKER_SESSION_TOKEN=change-me-in-production
