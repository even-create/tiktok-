NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# TikHub API (required for TikTok data sync)
TIKHUB_API_KEY=your-tikhub-api-key
# Optional: use China domain (https://api.tikhub.dev)
# TIKHUB_USE_CHINA_DOMAIN=true
# Optional: override API base URL
# TIKHUB_API_BASE_URL=https://api.tikhub.io

# Required for AI Insights (server-side only, never commit real keys)
# Can also be saved in Supabase via Settings page (takes priority over env)
GEMINI_API_KEY=your-gemini-api-key
# Default: gemini-2.0-flash
# GEMINI_MODEL=gemini-2.0-flash

# Skip TikHub if account synced within this many minutes (default 360 = 6h). Sync Now uses force=true.
SYNC_CACHE_MINUTES=360

# Vercel Cron: protect /api/cron/sync (Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=change-me-in-production

TRACKER_PASSWORD=zhaoeven
TRACKER_SESSION_TOKEN=change-me-in-production

# Deprecated (Apify removed — kept only if you still have old env vars locally)
# APIFY_TOKEN=
# APIFY_SYNC_CACHE_MINUTES=360
